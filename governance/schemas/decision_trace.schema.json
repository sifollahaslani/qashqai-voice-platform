{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/qashqai-voice/decision-trace.schema.json",
  "title": "QashqAI Voice Decision Trace",
  "type": "object",
  "required": [
    "decision_id",
    "timestamp",
    "requested_action",
    "result",
    "item_id",
    "recording_id",
    "actor",
    "input_records",
    "rules_evaluated",
    "reasons",
    "lifecycle_transition",
    "audit"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "pattern": "^decision-[0-9]{4}-[0-9]{6}$"
    },
    "timestamp": {
      "type": "string"
    },
    "requested_action": {
      "type": "string",
      "enum": [
        "transcription",
        "translation",
        "summarization",
        "embedding",
        "ai_training",
        "synthetic_voice",
        "dataset_creation",
        "institutional_export",
        "research_export",
        "public_release",
        "access_level_change",
        "revocation_update",
        "emergency_restriction"
      ]
    },
    "result": {
      "type": "string",
      "enum": [
        "allowed",
        "denied",
        "hold_for_review",
        "revoked",
        "emergency_restricted",
        "invalidated"
      ]
    },
    "item_id": {
      "type": "string"
    },
    "recording_id": {
      "type": "string"
    },
    "actor": {
      "type": "object",
      "required": [
        "actor_id",
        "role"
      ],
      "properties": {
        "actor_id": {
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "input_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "record_type",
          "record_id",
          "evidence_class"
        ],
        "properties": {
          "record_type": {
            "type": "string"
          },
          "record_id": {
            "type": "string"
          },
          "path_or_reference": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "evidence_class": {
            "type": "string",
            "enum": [
              "source_record",
              "governance_record",
              "review_finding",
              "derived_artifact",
              "machine_output",
              "inference",
              "external_claim"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "rules_evaluated": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "outcome"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "outcome": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "hold",
              "not_applicable"
            ]
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "unresolved_uncertainties": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_human_reviews": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "override": {
      "type": "object",
      "required": [
        "override_type"
      ],
      "properties": {
        "override_type": {
          "type": "string",
          "enum": [
            "none",
            "emergency_restriction",
            "clerical_correction",
            "scope_clarification"
          ]
        },
        "authority": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "lifecycle_transition": {
      "type": "object",
      "required": [
        "artifact_class",
        "prior_state",
        "requested_state",
        "final_state",
        "transition_id",
        "reversibility",
        "state_transition_result",
        "downstream_invalidation_required"
      ],
      "properties": {
        "artifact_class": {
          "type": "string"
        },
        "artifact_id": {
          "type": "string"
        },
        "prior_state": {
          "type": "string"
        },
        "requested_state": {
          "type": "string"
        },
        "final_state": {
          "type": "string"
        },
        "transition_id": {
          "type": "string"
        },
        "reversibility": {
          "type": "string",
          "enum": [
            "reversible",
            "reversible_to_more_restrictive",
            "restrictive",
            "partially_irreversible",
            "irreversible_or_not_fully_recallable"
          ]
        },
        "state_transition_result": {
          "type": "string",
          "enum": [
            "allowed",
            "denied",
            "hold_for_review",
            "revoked",
            "emergency_restricted",
            "invalidated"
          ]
        },
        "irreversibility_acknowledged": {
          "type": "boolean"
        },
        "downstream_invalidation_required": {
          "type": "boolean"
        },
        "downstream_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "artifact_id",
              "artifact_class",
              "current_state",
              "required_action"
            ],
            "properties": {
              "artifact_id": {
                "type": "string"
              },
              "artifact_class": {
                "type": "string"
              },
              "current_state": {
                "type": "string"
              },
              "required_action": {
                "type": "string",
                "enum": [
                  "none",
                  "hold",
                  "remove_from_future_use",
                  "quarantine",
                  "notify_partner",
                  "request_takedown",
                  "mark_not_fully_recallable",
                  "invalidate"
                ]
              },
              "recall_limit": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": [
        "audit_required",
        "audit_id",
        "decision_id"
      ],
      "properties": {
        "audit_required": {
          "type": "boolean"
        },
        "audit_id": {
          "type": "string"
        },
        "audit_log_path": {
          "type": "string"
        },
        "decision_id": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
